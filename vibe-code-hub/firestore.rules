rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // accessCodes: อ่านได้เฉพาะ user ที่ login แล้ว (สำหรับตรวจสอบสิทธิ์ VIP)
    // เขียนได้เฉพาะผ่าน Firebase Admin SDK เท่านั้น
    match /accessCodes/{document} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // userProgress: อ่าน/เขียนได้เฉพาะเจ้าของ document (userId ต้องตรงกับ UID ของ user ที่ login)
    match /userProgress/{progressId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ปฏิเสธการเข้าถึง collection อื่นทั้งหมดโดย default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
